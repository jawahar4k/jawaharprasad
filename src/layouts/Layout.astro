---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;
  isHome?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
}

const {
  title,
  description,
  path,
  isHome = false,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage = 'https://www.jawaharprasad.com/jawahar.jpg',
} = Astro.props;

const url = `https://www.jawaharprasad.com${path}`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={url} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (LinkedIn / Twitter sharing) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon: minimal text-based via SVG (no separate file needed) -->
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='80' font-size='90' font-family='system-ui,sans-serif' font-weight='700'%3EJ%3C/text%3E%3C/svg%3E" />
  </head>

  <body class="bg-white text-slate-900 antialiased">
    <main class="max-w-2xl mx-auto px-6 py-16 sm:py-24">
      {isHome ? (
        <header class="mb-16 flex items-center gap-6">
          <img
            src="/jawahar.jpg"
            alt="Jawahar Prasad"
            width="128"
            height="128"
            class="w-28 h-28 sm:w-32 sm:h-32 rounded-full object-cover ring-1 ring-slate-200 flex-shrink-0"
          />
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Jawahar Prasad</h1>
            <p class="mt-1 text-base sm:text-lg text-slate-600">
              Senior Director of Engineering · Tekion · Architecting AI dev productivity at scale
            </p>
          </div>
        </header>
      ) : (
        <header class="mb-12">
          <a href="/" class="group inline-flex items-center gap-3">
            <img
              src="/jawahar.jpg"
              alt="Jawahar Prasad"
              width="44"
              height="44"
              class="w-11 h-11 rounded-full object-cover ring-1 ring-slate-200 flex-shrink-0"
            />
            <span class="font-bold tracking-tight text-slate-900 underline decoration-transparent group-hover:decoration-slate-900 underline-offset-4 transition">Jawahar Prasad</span>
          </a>
        </header>
      )}

      <slot />

      <footer class="mt-16 pt-8 border-t border-slate-200 text-sm text-slate-500">
        <nav aria-label="Site" class="mb-3 flex flex-wrap gap-x-5 gap-y-1">
          <a href="/" class="underline decoration-slate-300 hover:decoration-slate-900 underline-offset-4 transition">Home</a>
          <a href="/about" class="underline decoration-slate-300 hover:decoration-slate-900 underline-offset-4 transition">About</a>
          <a href="/leadership" class="underline decoration-slate-300 hover:decoration-slate-900 underline-offset-4 transition">How I lead</a>
          <a href="https://www.linkedin.com/in/jawaharprasad" rel="noopener" class="underline decoration-slate-300 hover:decoration-slate-900 underline-offset-4 transition">LinkedIn</a>
          <a href="https://github.com/jawahar4k" rel="noopener" class="underline decoration-slate-300 hover:decoration-slate-900 underline-offset-4 transition">GitHub</a>
        </nav>
        © Jawahar Prasad · jawaharprasad.com
      </footer>
    </main>
  </body>
</html>
